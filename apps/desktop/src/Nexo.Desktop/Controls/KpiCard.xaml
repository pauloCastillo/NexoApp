<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Nexo.Desktop.Controls.KpiCard">
    <Frame Padding="16" CornerRadius="12" HasShadow="True"
           BackgroundColor="{Binding CardColor}"
           BorderColor="Transparent"
           HeightRequest="100">
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">
            <Label Grid.Row="0" Grid.Column="0"
                   Text="{Binding Icon}" FontSize="24"
                   VerticalOptions="Start" />
            <VerticalStackLayout Grid.Row="0" Grid.Column="1"
                                 Spacing="2" Margin="8,0,0,0">
                <Label Text="{Binding Value}"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="{Binding TextColor}" />
                <Label Text="{Binding Title}"
                       FontSize="13" TextColor="{Binding TextColor}"
                       Opacity="0.8" />
                <Label Text="{Binding Subtitle}"
                       FontSize="11" TextColor="{Binding TextColor}"
                       Opacity="0.6"
                       IsVisible="{Binding Subtitle, Converter={StaticResource StringNotEmptyConverter}}" />
            </VerticalStackLayout>
        </Grid>
    </Frame>
</ContentView>
