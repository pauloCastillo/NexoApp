<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#1E3A5F</Color>
    <Color x:Key="PrimaryDark">#152B45</Color>
    <Color x:Key="PrimaryLight">#2E5A8F</Color>
    <Color x:Key="Secondary">#4CAF50</Color>
    <Color x:Key="Accent">#FF6B35</Color>
    <Color x:Key="Danger">#E53935</Color>
    <Color x:Key="Warning">#FFC107</Color>
    <Color x:Key="Info">#2196F3</Color>
    <Color x:Key="Success">#4CAF50</Color>

    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#666666</Color>
    <Color x:Key="TextLight">#999999</Color>
    <Color x:Key="Surface">#F5F7FA</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="BorderColor">#E0E0E0</Color>

    <Color x:Key="SocketConnected">#4CAF50</Color>
    <Color x:Key="SocketDisconnected">#E53935</Color>
    <Color x:Key="SocketReconnecting">#FFC107</Color>

    <Color x:Key="KpiTotal">#1E3A5F</Color>
    <Color x:Key="KpiActive">#4CAF50</Color>
    <Color x:Key="KpiBreak">#FF9800</Color>
    <Color x:Key="KpiLate">#E53935</Color>
</ResourceDictionary>
