<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Nexo.Desktop.ViewModels"
             xmlns:controls="clr-namespace:Nexo.Desktop.Controls"
             x:Class="Nexo.Desktop.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="16">

                <!-- Socket Status -->
                <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                    <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                             Color="{Binding SocketStatusColor}" VerticalOptions="Center" />
                    <Label Text="{Binding SocketStatusText}" Style="{StaticResource Caption}" />
                </HorizontalStackLayout>

                <!-- KPI Cards -->
                <CollectionView ItemsSource="{Binding KpiCards}"
                                ItemsLayout="HorizontalList"
                                HeightRequest="120">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <controls:KpiCard WidthRequest="160" Margin="4,0" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Period Selector -->
                <HorizontalStackLayout Spacing="8">
                    <Label Text="Período:" Style="{StaticResource Caption}" VerticalOptions="Center" />
                    <Picker ItemsSource="{Binding Periods}"
                            SelectedItem="{Binding SelectedPeriod}"
                            WidthRequest="120" />
                </HorizontalStackLayout>

                <!-- Timeline -->
                <Label Text="Marcajes del Día" Style="{StaticResource Subheadline}" />
                <CollectionView ItemsSource="{Binding TimeControls}"
                                EmptyView="No hay marcajes registrados hoy">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Frame Style="{StaticResource Card}" Margin="0,4">
                                <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="12">
                                    <Label Text="{Binding Entrada}"
                                           FontSize="16" FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Employee.Username}"
                                               FontSize="15" FontAttributes="Bold" />
                                        <Label Text="{Binding Late, StringFormat='{0}'}"
                                               FontSize="11"
                                               IsVisible="False" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2"
                                           Text="{Binding Salida, TargetNullValue='Activo'}"
                                           FontSize="12" TextColor="{StaticResource TextSecondary}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" />

                <!-- Error -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource Danger}"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
