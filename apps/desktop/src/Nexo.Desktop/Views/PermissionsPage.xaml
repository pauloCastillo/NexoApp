<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Nexo.Desktop.ViewModels"
             x:Class="Nexo.Desktop.Views.PermissionsPage"
             x:DataType="vm:PermissionViewModel"
             Title="Permisos">

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
        <VerticalStackLayout Spacing="12" Padding="16">
            <HorizontalStackLayout Spacing="8">
                <Label Text="Estado:" Style="{StaticResource Caption}" VerticalOptions="Center" />
                <Picker ItemsSource="{Binding StatusFilters}"
                        SelectedItem="{Binding SelectedStatus}"
                        WidthRequest="140" />
            </HorizontalStackLayout>

            <Label Text="{Binding TotalText}" Style="{StaticResource Caption}" />

            <CollectionView ItemsSource="{Binding Permissions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Frame Style="{StaticResource Card}" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="4">
                                <Label Text="{Binding Employee}" FontSize="14" FontAttributes="Bold" />
                                <Label Grid.Row="1" Text="{Binding Type}" FontSize="12"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Grid.Row="2" Text="{Binding Reason}" FontSize="11"
                                       TextColor="{StaticResource TextLight}"
                                       LineBreakMode="TailTruncation" />
                                <Frame Grid.Column="1" Grid.RowSpan="3"
                                       Padding="8,4" CornerRadius="8"
                                       BackgroundColor="{StaticResource Surface}"
                                       HasShadow="False" VerticalOptions="Center">
                                    <Label Text="{Binding Status}" FontSize="11" />
                                </Frame>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
