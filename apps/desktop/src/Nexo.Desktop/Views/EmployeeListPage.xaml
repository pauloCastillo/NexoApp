<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Nexo.Desktop.ViewModels"
             x:Class="Nexo.Desktop.Views.EmployeeListPage"
             x:DataType="vm:EmployeeListViewModel"
             Title="Empleados">

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
        <VerticalStackLayout Spacing="12" Padding="16">

            <!-- Search -->
            <SearchBar Placeholder="Buscar empleado..."
                       Text="{Binding SearchQuery}"
                       SearchCommand="{Binding SearchCommand}" />

            <!-- Total -->
            <Label Text="{Binding TotalText}" Style="{StaticResource Caption}" />

            <!-- List -->
            <CollectionView ItemsSource="{Binding Employees}"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Frame Style="{StaticResource Card}" Margin="0,4">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Frame WidthRequest="44" HeightRequest="44"
                                       CornerRadius="22" Padding="0"
                                       BackgroundColor="{StaticResource Primary}"
                                       HasShadow="False">
                                    <Label Text="👤" FontSize="20"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Username}"
                                           FontSize="15" FontAttributes="Bold" />
                                    <Label Text="{Binding Email}"
                                           FontSize="12" TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2"
                                       Text="{Binding Role}"
                                       FontSize="12" TextColor="{StaticResource TextLight}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </RefreshView>
</ContentPage>
