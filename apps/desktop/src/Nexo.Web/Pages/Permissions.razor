@page "/permissions"
@inject PermissionViewModel ViewModel

<PageTitle>Permisos</PageTitle>

<div class="d-flex gap-2 align-items-center mb-3">
    <h3 class="mb-0">Permisos</h3>
    <select class="form-select form-select-sm w-auto" @bind="ViewModel.SelectedStatus"
            @bind:after="() => ViewModel.LoadCommand.ExecuteAsync(null)">
        <option value="">Todos</option>
        @foreach (var s in ViewModel.StatusFilters.Skip(1))
        {
            <option value="@s">@s</option>
        }
    </select>
</div>

@if (ViewModel.IsBusy && !ViewModel.Permissions.Any())
{
    <div class="text-center py-5"><div class="spinner-border"></div></div>
}
else
{
    <div class="list-group">
        @foreach (var p in ViewModel.Permissions)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="fw-bold">@p.Employee</div>
                        <small class="text-muted">@p.Reason</small>
                        <div><small>@p.StartDate.ToString("dd/MM/yy") - @p.EndDate.ToString("dd/MM/yy")</small></div>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-secondary">@p.Type</span>
                        <span class="badge @GetStatusBadge(p.Status)">@p.Status</span>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    static string GetStatusBadge(string s) => s switch
    {
        "aprobado" => "bg-success",
        "rechazado" => "bg-danger",
        _ => "bg-warning text-dark"
    };
}
