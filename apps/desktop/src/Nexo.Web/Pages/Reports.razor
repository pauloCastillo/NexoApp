@page "/reports"
@inject ReportViewModel ViewModel

<PageTitle>Reportes</PageTitle>

<h3>Reportes</h3>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Tipo de Reporte</label>
            <select class="form-select" @bind="ViewModel.SelectedReportType">
                @foreach (var t in ViewModel.ReportTypes)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Desde</label>
                <input type="date" class="form-control" @bind="ViewModel.FromDate" />
            </div>
            <div class="col">
                <label class="form-label">Hasta</label>
                <input type="date" class="form-control" @bind="ViewModel.ToDate" />
            </div>
        </div>

        <button class="btn btn-primary" @onclick="() => ViewModel.ExportCsvCommand.Execute(null)"
                disabled="@ViewModel.IsBusy">
            @if (ViewModel.IsBusy)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            Exportar CSV
        </button>

        @if (!string.IsNullOrEmpty(ViewModel.ExportStatus))
        {
            <div class="alert alert-info mt-3">@ViewModel.ExportStatus</div>
        }
    </div>
</div>
